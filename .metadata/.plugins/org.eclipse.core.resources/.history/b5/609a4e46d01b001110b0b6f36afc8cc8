package com.yourcompany.simpleorm.session;

import java.sql.Connection;
import java.sql.SQLException;
import java.util.Objects;
import java.util.Optional;

import com.yourcompany.simpleorm.jdbc.ConnectionManager;
import com.yourcompany.simpleorm.util.OrmMetadataExtractor;
import com.yourcompany.simpleorm.metadata.OrmMetadata;

public class SimpleOrmSession implements OrmSession {

    private Connection connection;

    public SimpleOrmSession(Connection connection) {
        this.connection = Objects.requireNonNull(connection,
                "Database connection cannot be null for OrmSession.");

        try {
            if (this.connection.isClosed()) {
                throw new IllegalArgumentException(
                        "Cannot create OrmSession with a closed database connection.");
            }

            System.out.println("SimpleOrmSession created with active connection: " + this.connection);

        } catch (SQLException e) {
            throw new RuntimeException(
                    "Failed to verify connection status during OrmSession creation.", e);
        }
    }

    @Override
    public void save(Object entity) {

        if (entity == null) {
            throw new NullPointerException("Entity cannot be null.");
        }

        Class<?> entityClass = entity.getClass();

        System.out.println(
                "SimpleOrmSession.save() called for entity: " + entityClass.getSimpleName());

        // Retrieve ORM metadata
        OrmMetadata<?> metadata = OrmMetadataExtractor.getMetadata(entityClass);

        System.out.println(
                "   (Obtained metadata for table: " + metadata.tableName() + ") - IMPLEMENTATION PENDING");
    }

    @Override
    public <T> Optional<T> findById(Class<T> clazz, Object id) {

        if (clazz == null) {
            throw new NullPointerException("Class cannot be null.");
        }

        if (id == null) {
            throw new NullPointerException("ID cannot be null.");
        }

        System.out.println("SimpleOrmSession.findById() called for class: "
                + clazz.getSimpleName() + ", id: " + id);

        // Retrieve ORM metadata
        OrmMetadata<T> metadata = OrmMetadataExtractor.getMetadata(clazz);

        System.out.println(
                "   (Obtained metadata for table: " + metadata.tableName() + ") - IMPLEMENTATION PENDING");

        return Optional.empty();
    }

    @Override
    public void close() throws Exception {

        System.out.println("Closing SimpleOrmSession...");

        ConnectionManager.closeConnection(this.connection);

        this.connection = null;

        System.out.println("SimpleOrmSession closed.");
    }
}