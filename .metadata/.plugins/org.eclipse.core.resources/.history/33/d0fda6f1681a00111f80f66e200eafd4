package com.yourcompany.simpleorm.util;

import java.lang.reflect.Field;
import java.lang.reflect.Modifier;
import java.util.ArrayList;
import java.util.List;

import com.yourcompany.simpleorm.annotation.Column;
import com.yourcompany.simpleorm.annotation.Id;
import com.yourcompany.simpleorm.annotation.Table;
public class OrmMetadataExtractor {
	public static String getTableName(Class<?> clazz)
	{
		if(clazz == null)
		{
			throw new NullPointerException("Input Class cannot be null");
		}
		if(clazz.isAnnotationPresent(Table.class))
		{
			Table tableAnnotation = clazz.getAnnotation(Table.class);
			return tableAnnotation.name();
		}
		else
		{
			return clazz.getSimpleName().toLowerCase();
		}
	}
	public static String getPrimaryKeyFieldName(Class<?> clazz) {
        if (clazz == null) {
            throw new NullPointerException("Input class cannot be null.");
        }

        String primaryKeyFieldName = null;

        
        Field[] fields = clazz.getDeclaredFields();

    
        for (Field field : fields) {
            
            if (field.isAnnotationPresent(Id.class)) {
                
                if (primaryKeyFieldName != null) {
                    
                    throw new IllegalStateException("Entity class '" + clazz.getName() +
                            "' must have exactly one @Id annotation, but found multiple: [" +
                            primaryKeyFieldName + ", " + field.getName() + "]");
                }
                primaryKeyFieldName = field.getName();
            }
        }
        if (primaryKeyFieldName == null) {
            throw new IllegalStateException("Entity class '" + clazz.getName() +
                    "' must have exactly one field annotated with @Id, but none was found.");
        }
        return primaryKeyFieldName;
    }
	 public static String getColumnName(Field field) {
	        if (field == null) {
	            throw new NullPointerException("Input field cannot be null.");
	        }
	        if (field.isAnnotationPresent(Column.class)) {
	            Column columnAnnotation = field.getAnnotation(Column.class);
	            return columnAnnotation.name();
	        } else {
	            return field.getName().toLowerCase();
	        }
	    }
	 
	 public static List<Field> getMappedColumnFields(Class<?> clazz)
	 {
		 if(clazz == null)
		 {
			 throw new NullPointerException("Input class cannot be null.");
		 }
		 List<Field> mappedFields = new ArrayList<Field>();
		 Field[] allDeclaredFields = clazz.getDeclaredFields();
		 
		 for(Field field: allDeclaredFields)
		 {
			 if(Modifier.isStatic(field.getModifiers()))
			 {
				 continue;
			 }
			 mappedFields.add(field);
		 }
		 
		 return mappedFields;
		 
	 }
	 
}
